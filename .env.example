# Copy this file to .env to override the defaults.
# All variables are optional — the defaults point at the local mock server.

# Base URL of the API (mock server runs on http://localhost:3000)
VITE_API_BASE_URL=http://localhost:3000

# Tenant, blueprint, and (optional) blueprint version IDs
VITE_TENANT_ID=1
VITE_BLUEPRINT_ID=bp_01jk766tckfwx84xjcxazggzyc

# Set this only when targeting the production endpoint that requires a version segment.
# Leave empty for the mock server.
# VITE_BLUEPRINT_VERSION_ID=bpv_123
